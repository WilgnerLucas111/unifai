# ============================================================================
# .env.example — UnifAI little7-installer Bootstrap Environment Template
# ============================================================================
# This file demonstrates how to securely inject secrets into the bootstrap
# process using environment variables with least-privilege principles.
#
# Usage:
#   1. Copy this file to .env.local (or any secure location):
#      cp .env.example .env.local
#
#   2. Set file permissions to 0600 (readable by you only):
#      chmod 0600 .env.local
#
#   3. Source the environment before running stages:
#      source .env.local
#      ./install.sh 21  # Or any stage that needs secrets
#
#   4. After bootstrap, securely delete:
#      shred -vfz -n 5 .env.local
#
# SECURITY CONSIDERATIONS:
#   • NEVER commit .env files to version control
#   • NEVER pass secrets as command-line arguments
#   • ALWAYS use file-based injection with restricted permissions (0600)
#   • ALWAYS rotate secrets after installation
#   • ALWAYS audit access to secret files (/var/log/audit/)
#
# ============================================================================

# ============================================================================
# Stage 21: Cloud LLM Secrets (SecretVault seeding)
# ============================================================================

# Cloud LLM Provider selection
# Options: codex-oauth (Anthropic/Claude), openai-oauth (OpenAI)
# If not set, the stage will prompt interactively
export LITTLE7_CLOUD_PROVIDER=codex-oauth

# Cloud API Key — for seeding into SecretVault
# This should be a valid API key from your cloud provider
# IMPORTANT: This value is only used during Stage 21 bootstrap.
#            After seeding, the raw key is never written to disk.
#            It is stored encrypted in SecretVault.
# Replace <YOUR_API_KEY_HERE> with your actual key (e.g., obtained from https://console.anthropic.com)
export LITTLE7_CLOUD_API_KEY=<YOUR_API_KEY_HERE>

# ============================================================================
# Stage 00 (Advanced): Manual Node.js Version Override
# ============================================================================

# Normally, Node.js version is read from bootstrap-config.lock.
# To override the pinned version (NOT RECOMMENDED):
# export LITTLE7_NODEJS_VERSION=20.13.0

# ============================================================================
# Stage 50 (Advanced): OpenClaw Release Override
# ============================================================================

# Normally, OpenClaw version is read from bootstrap-config.lock.
# To override the pinned version (NOT RECOMMENDED):
# export LITTLE7_OPENCLAW_VERSION=1.5.2

# ============================================================================
# Bootstrap Control Flags (Experts Only)
# ============================================================================

# Enable controlled refresh of pinned dependencies
# WARNING: This allows pulling from remote git repos.
# Only use during recovery or scheduled updates.
# export LITTLE7_REFRESH_BOOTSTRAP=1

# Skip bootstrap lock file verification (NOT RECOMMENDED)
# WARNING: This disables checksum verification.
# export LITTLE7_SKIP_LOCK_CHECK=1

# ============================================================================
# Service Principal Configuration (Stage 20)
# ============================================================================

# Default service user that runs supervisor, watchdog, and other services
# If you want to use a custom non-root user, set this BEFORE Stage 20:
export LITTLE7_SERVICE_USER=unifai-operator
export LITTLE7_SERVICE_GROUP=unifai-operator

# ============================================================================
# Docker Runtime Configuration (Stage 31)
# ============================================================================

# Bill Proxy port (used by OpenClaw for upstream routing)
export BILL_PROXY_PORT=7701

# ============================================================================
# Master Key Bootstrap (Stage 20 - Automated Generation)
# ============================================================================

# IMPORTANT: Stage 20 generates the SecretVault master key automatically.
# DO NOT pre-generate or provide it here.
# The key is created by: openssl rand -hex 32
# Location: /etc/little7/secretvault_master.key (perms: 0600, root-only)
#
# If you need to inject a pre-generated key (e.g., during recovery):
# 1. Ensure key file exists and has correct permissions before Stage 20
# 2. Stage 20 will skip generation if file already exists
# 3. Verify key is 64 hex characters (32 bytes): echo -n "$KEY" | wc -c

# ============================================================================
# Audit and Compliance
# ============================================================================

# Enable extended audit logging (Linux auditctl)
# This logs all access to /etc/little7/secretvault_master.key
export LITTLE7_ENABLE_AUDIT_LOGGING=1

# Email for security alerts (optional)
# export LITTLE7_SECURITY_ALERT_EMAIL=ops@unifai.local

# ============================================================================
# Example Workflow
# ============================================================================

# Step 1: Create secure .env file
#   cp .env.example .env.local
#   chmod 0600 .env.local

# Step 2: Edit with your secrets (using a secure text editor)
#   nano .env.local    # or vim, emacs, etc.

# Step 3: Source and run bootstrap
#   source .env.local
#   ./install.sh all

# Step 4: Securely delete after bootstrap
#   shred -vfz -n 5 .env.local

# Step 5: Verify installation
#   systemctl status lyra-supervisor.service
#   systemctl status lyra-webui.service

# ============================================================================
# Troubleshooting
# ============================================================================

# Q: "Missing LITTLE7_CLOUD_API_KEY" error
# A: Set it before running Stage 21:
#    export LITTLE7_CLOUD_API_KEY=sk-ant-...
#    ./install.sh 21

# Q: Can I re-run Stage 21 with a different provider?
# A: Yes! Just set new env vars and re-run:
#    export LITTLE7_CLOUD_PROVIDER=openai-oauth
#    export LITTLE7_CLOUD_API_KEY=sk-...
#    ./install.sh 21

# Q: Where is my API key stored after Stage 21?
# A: Encrypted in SecretVault at /etc/little7/secrets/
#    Raw keys are never written to disk outside SecretVault.
#    Access is audited via systemd-journald.

